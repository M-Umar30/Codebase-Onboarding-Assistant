# --- LLM providers ---
OPENAI_API_KEY=
GROQ_API_KEY=

# --- database ---
DATABASE_URL=postgresql://onboard:onboard@localhost:5432/onboard

# --- embeddings ---
EMBEDDER_PROVIDER=openai   # openai | local
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- per-node model assignment (env-overridable, never hardcoded in node code) ---
PLANNER_PROVIDER=groq
PLANNER_MODEL=llama-3.3-70b-versatile

DRAFTER_PROVIDER=groq
DRAFTER_MODEL=llama-3.3-70b-versatile

CRITIC_PROVIDER=openai
CRITIC_MODEL=gpt-4o-mini

SYNTHESIZER_PROVIDER=openai
SYNTHESIZER_MODEL=gpt-4o-mini
