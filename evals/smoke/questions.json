        "security/http.py",
        "security/utils.py"
      ]
    },
    {
      "id": "fastapi_http_basic",
      "repo_id": "smoke-fastapi",
      "question": "How is HTTP Basic authentication implemented and how are the username and password decoded?",
      "expected_files": [
        "security/http.py"
      ]
    },
    {
      "id": "fastapi_oauth2_password_bearer",
      "repo_id": "smoke-fastapi",
      "question": "How does OAuth2PasswordBearer extract the bearer token from a request?",
      "expected_files": [
        "security/oauth2.py"
      ]
    },
    {
      "id": "fastapi_api_key",
      "repo_id": "smoke-fastapi",
      "question": "How are API keys read from a header, query parameter, or cookie?",
      "expected_files": [
        "security/api_key.py"
      ]
    },
    {
      "id": "fastapi_exception_handlers",
      "repo_id": "smoke-fastapi",
      "question": "How are request validation errors turned into an HTTP response?",
      "expected_files": [
        "exception_handlers.py"
      ]
    },
    {
      "id": "fastapi_dependencies",
      "repo_id": "smoke-fastapi",
